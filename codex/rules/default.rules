prefix_rule(pattern=["sudo"], decision="forbidden", justification="Never run privileged commands without explicit manual intervention outside Codex.")
prefix_rule(pattern=["su"], decision="forbidden", justification="Never switch users inside Codex automation.")
prefix_rule(pattern=["passwd"], decision="forbidden", justification="Credential-changing flows should not be automated through Codex.")
prefix_rule(pattern=["shutdown"], decision="forbidden", justification="System shutdown is always high risk.")
prefix_rule(pattern=["reboot"], decision="forbidden", justification="System reboot is always high risk.")
prefix_rule(pattern=["halt"], decision="forbidden", justification="System halt is always high risk.")
prefix_rule(pattern=["poweroff"], decision="forbidden", justification="System power operations should never be auto-approved.")
prefix_rule(pattern=["diskutil", "eraseDisk"], decision="forbidden", justification="Disk erasure should never be auto-approved.")
prefix_rule(pattern=["dd"], decision="forbidden", justification="Raw block device writes are too risky for automatic execution.")
prefix_rule(pattern=["mkfs"], decision="forbidden", justification="Filesystem formatting should never be auto-approved.")
prefix_rule(pattern=["git", "reset", "--hard"], decision="forbidden", justification="Destructive history resets should never be auto-approved.")
prefix_rule(pattern=["git", "clean", "-fd"], decision="forbidden", justification="Removing untracked files should never be auto-approved.")
prefix_rule(pattern=["git", "clean", "-fdx"], decision="forbidden", justification="Removing ignored and untracked files should never be auto-approved.")

